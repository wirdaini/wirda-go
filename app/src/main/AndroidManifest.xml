<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Wirdago"
        tools:targetApi="31">

        <!-- LAUNCHER ACTIVITY (Halaman pertama saat app dibuka) -->
        <activity
            android:name=".pertemuan_3.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- WELCOME ACTIVITY (Setelah login sukses) -->
        <activity
            android:name=".pertemuan_3.WelcomeActivity"
            android:exported="false" />

        <!-- RUMUS BANGUN RUANG -->
        <activity
            android:name=".pertemuan_2.BangunKalkulatorActivity"
            android:exported="false" />

        <!-- JOB BOARD ACTIVITY -->
        <activity
            android:name=".pertemuan_4.JobBoardActivity"
            android:exported="false" />

        <!-- PORTOFOLIO ACTIVITY -->
        <activity
            android:name=".pertemuan_4.PortofolioActivity"
            android:exported="false" />

    </application>

</manifest>