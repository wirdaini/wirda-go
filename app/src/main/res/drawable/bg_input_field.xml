<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Warna background putih bersih -->
    <solid android:color="@color/sr_white" />

    <!-- Garis tepi tipis warna abu -->
    <stroke
        android:width="1dp"
        android:color="@color/sr_border" />

    <!-- Sudut membulat -->
    <corners android:radius="8dp" />

    <!-- Ruang di dalam field agar teks tidak mepet -->
    <padding
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp" />

</shape>