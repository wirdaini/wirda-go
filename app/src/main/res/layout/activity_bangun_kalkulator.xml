<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_welcome"
    tools:context=".pertemuan_2.BangunKalkulatorActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- BANGUN DATAR: LAYANG-LAYANG -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bangun Datar - Layang-layang"
                android:textColor="@color/text_heading"
                android:textSize="20sp"
                android:textStyle="bold"
                android:padding="10dp"/>

            <LinearLayout
                android:id="@+id/llRumus1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:src="@drawable/rumus_layanglayang"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llInput1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Diagonal 1"
                    android:textColor="@color/text_default"
                    android:textSize="18sp"/>

                <EditText
                    android:id="@+id/etDiagonal1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Masukkan panjang diagonal 1"
                    android:inputType="numberDecimal"
                    android:textSize="18sp"
                    android:background="@color/input_background"
                    android:padding="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Diagonal 2"
                    android:textColor="@color/text_default"
                    android:textSize="18sp"
                    android:layout_marginTop="12dp"/>

                <EditText
                    android:id="@+id/etDiagonal2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Masukkan panjang diagonal 2"
                    android:inputType="numberDecimal"
                    android:textSize="18sp"
                    android:background="@color/input_background"
                    android:padding="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sisi Pendek"
                    android:textColor="@color/text_default"
                    android:textSize="18sp"
                    android:layout_marginTop="12dp"/>

                <EditText
                    android:id="@+id/etSisiPendek"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Masukkan sisi pendek"
                    android:inputType="numberDecimal"
                    android:textSize="18sp"
                    android:background="@color/input_background"
                    android:padding="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sisi Panjang"
                    android:textColor="@color/text_default"
                    android:textSize="18sp"
                    android:layout_marginTop="12dp"/>

                <EditText
                    android:id="@+id/etSisiPanjang"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Masukkan sisi panjang"
                    android:inputType="numberDecimal"
                    android:textSize="18sp"
                    android:background="@color/input_background"
                    android:padding="12dp"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llHitung1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <Button
                    android:id="@+id/btnKeliling"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hitung Keliling"
                    android:backgroundTint="@color/button_primary"
                    android:textColor="@color/button_text"
                    android:layout_margin="8dp"
                    android:padding="12dp"/>

                <Button
                    android:id="@+id/btnLuas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hitung Luas"
                    android:backgroundTint="@color/button_secondary"
                    android:textColor="@color/button_text"
                    android:layout_margin="8dp"
                    android:padding="12dp"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llHasilKeliling"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingLeft="20dp"
                android:paddingTop="20dp"
                android:paddingRight="20dp">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="Keliling"
                    android:textColor="@color/text_default"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" : "
                    android:textColor="@color/text_default"
                    android:textSize="18sp"/>

                <TextView
                    android:id="@+id/tvKeliling"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llHasilLuas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingLeft="20dp"
                android:paddingTop="20dp"
                android:paddingRight="20dp">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="Luas"
                    android:textColor="@color/text_default"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" : "
                    android:textColor="@color/text_default"
                    android:textSize="18sp"/>

                <TextView
                    android:id="@+id/tvLuas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- BANGUN RUANG: BOLA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bangun Ruang - Bola"
                android:textColor="@color/text_heading"
                android:textSize="20sp"
                android:textStyle="bold"
                android:padding="10dp"
                android:layout_marginTop="16dp"/>

            <LinearLayout
                android:id="@+id/llRumus2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:src="@drawable/rumus_bola"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llInput2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jari-jari"
                    android:textColor="@color/text_default"
                    android:textSize="18sp"/>

                <EditText
                    android:id="@+id/etJariJari"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Masukkan Jari-jari"
                    android:inputType="numberDecimal"
                    android:textSize="18sp"
                    android:background="@color/input_background"
                    android:padding="12dp"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llHitung2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <Button
                    android:id="@+id/btnLuasBola"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hitung Luas"
                    android:backgroundTint="@color/button_accent"
                    android:textColor="@color/button_text"
                    android:layout_margin="8dp"
                    android:padding="12dp"/>

                <Button
                    android:id="@+id/btnVolume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hitung Volume"
                    android:backgroundTint="@color/button_webview"
                    android:textColor="@color/button_text"
                    android:layout_margin="8dp"
                    android:padding="12dp"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llHasilVolume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingLeft="20dp"
                android:paddingTop="20dp"
                android:paddingRight="20dp">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="Volume"
                    android:textColor="@color/text_default"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" : "
                    android:textColor="@color/text_default"
                    android:textSize="18sp"/>

                <TextView
                    android:id="@+id/tvVolume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llHasilLuasBola"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingLeft="20dp"
                android:paddingTop="20dp"
                android:paddingRight="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="Luas Bola"
                    android:textColor="@color/text_default"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" : "
                    android:textColor="@color/text_default"
                    android:textSize="18sp"/>

                <TextView
                    android:id="@+id/tvLuasBola"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>