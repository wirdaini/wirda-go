<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_welcome"
    tools:context=".Home.pertemuan_4.PortofolioActivity">

    <!-- Header Image -->
    <ImageView
        android:id="@+id/ivHeaderPortofolio"
        android:layout_width="0dp"
        android:layout_height="150dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_portofolio"
        android:contentDescription="@string/desc_portofolio"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Divider -->
    <View
        android:id="@+id/dividerTop"
        android:layout_width="60dp"
        android:layout_height="3dp"
        android:background="@color/divider"
        app:layout_constraintTop_toBottomOf="@id/ivHeaderPortofolio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <!-- Judul Halaman -->
    <TextView
        android:id="@+id/tvJudulPortofolio"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Portofolio Saya"
        android:textSize="24sp"
        android:textColor="@color/text_title"
        android:fontFamily="@font/poppins_bold"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/dividerTop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    <!-- Deskripsi -->
    <TextView
        android:id="@+id/tvDeskripsiPortofolio"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Bangun portofolio luar biasa untuk menarik klien"
        android:textSize="14sp"
        android:textColor="@color/text_subtitle"
        android:fontFamily="@font/inter_18pt_regular"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvJudulPortofolio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tombol Tambah Portofolio -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTambahPortofolio"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="+ Tambah Portofolio Baru"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        app:cornerRadius="12dp"
        android:backgroundTint="@color/button_login_start"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvDeskripsiPortofolio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtitle Daftar Proyek -->
    <TextView
        android:id="@+id/tvSubtitleProyek"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="📁 Proyek Terbaru"
        android:textSize="16sp"
        android:textColor="@color/text_title"
        android:fontFamily="@font/poppins_bold"
        android:paddingHorizontal="24dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnTambahPortofolio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ScrollView untuk daftar portofolio -->
    <ScrollView
        android:id="@+id/scrollPortofolioList"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitleProyek"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Portofolio Card 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/background_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/ic_project1"
                            android:contentDescription="@string/desc_project_image"
                            android:scaleType="centerCrop"
                            app:cornerRadius="8dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Aplikasi Task Management"
                                android:textSize="14sp"
                                android:textColor="@color/text_title"
                                android:fontFamily="@font/poppins_bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="UI/UX Design • 2024"
                                android:textSize="11sp"
                                android:textColor="@color/text_subtitle" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⭐ 4.8"
                                android:textSize="12sp"
                                android:textColor="@color/button_login_start"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Edit"
                            android:textSize="12sp"
                            android:textColor="@color/button_login_start"
                            android:padding="8dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Aplikasi manajemen tugas dengan fitur kolaborasi real-time dan notifikasi pintar."
                        android:textSize="12sp"
                        android:textColor="@color/text_subtitle"
                        android:layout_marginTop="12dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Portofolio Card 2 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/background_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/ic_project2"
                            android:contentDescription="@string/desc_project_image"
                            android:scaleType="centerCrop"
                            app:cornerRadius="8dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Website Portofolio"
                                android:textSize="14sp"
                                android:textColor="@color/text_title"
                                android:fontFamily="@font/poppins_bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Web Development • 2024"
                                android:textSize="11sp"
                                android:textColor="@color/text_subtitle" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⭐ 4.9"
                                android:textSize="12sp"
                                android:textColor="@color/button_login_start"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Edit"
                            android:textSize="12sp"
                            android:textColor="@color/button_login_start"
                            android:padding="8dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Website portofolio personal dengan animasi modern dan responsive design."
                        android:textSize="12sp"
                        android:textColor="@color/text_subtitle"
                        android:layout_marginTop="12dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Portofolio Card 3 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/background_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/ic_project3"
                            android:contentDescription="@string/desc_project_image"
                            android:scaleType="centerCrop"
                            app:cornerRadius="8dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Brand Identity"
                                android:textSize="14sp"
                                android:textColor="@color/text_title"
                                android:fontFamily="@font/poppins_bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Graphic Design • 2023"
                                android:textSize="11sp"
                                android:textColor="@color/text_subtitle" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⭐ 4.7"
                                android:textSize="12sp"
                                android:textColor="@color/button_login_start"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Edit"
                            android:textSize="12sp"
                            android:textColor="@color/button_login_start"
                            android:padding="8dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Desain logo, kartu nama, dan media sosial untuk startup lokal."
                        android:textSize="12sp"
                        android:textColor="@color/text_subtitle"
                        android:layout_marginTop="12dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>